---
---
<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="#home" class="nav-logo" aria-label="MMP Appliances Trading">
      <span class="mmp-mark nav-mark">
        <span class="l1">M</span><span class="l2">M</span><span class="l3">P</span>
      </span>
      <span class="nav-sub">Appliances Trading</span>
    </a>

    <ul class="nav-links" id="navLinks">
      <li><a href="#home">Home</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#brands">Brands</a></li>
      <li><a href="#posts">Posts</a></li>
      <li><a href="#services">Services</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>

    <a href="https://www.facebook.com/mmp.iligan" target="_blank" rel="noopener" class="nav-fb-btn">
      <i class="fi fi-br-facebook"></i>
      Follow Us
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 1rem 2.5rem;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, box-shadow 0.3s, padding 0.3s;
  }

  .navbar.scrolled {
    border-bottom-color: var(--border);
    box-shadow: 0 2px 20px rgba(11,20,36,0.08);
    padding: 0.65rem 2.5rem;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Logo */
  .nav-logo {
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .nav-mark { font-size: 1.9rem; }

  .nav-sub {
    font-family: var(--font-condensed);
    font-size: 0.58rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ink-light);
    font-weight: 600;
    padding-bottom: 2px;
  }

  /* Links */
  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--ink-mid);
    font-family: var(--font-condensed);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 0.4rem 0.8rem;
    border-radius: 3px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--red);
    background: var(--red-light);
  }

  /* FB Button */
  .nav-fb-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.1rem;
    background: #1877F2;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-condensed);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border-radius: 3px;
    transition: background 0.2s, transform 0.2s;
    flex-shrink: 0;
  }
  .nav-fb-btn:hover { background: #1558b0; transform: translateY(-1px); }
  .nav-fb-btn i { font-size: 0.9rem; }

  /* Toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }
  .nav-toggle span {
    display: block;
    width: 22px; height: 2px;
    background: var(--navy);
    border-radius: 2px;
    transition: transform 0.3s;
  }

  @media (max-width: 900px) {
    .nav-toggle { display: flex; }
    .nav-fb-btn { display: none; }

    .nav-links {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(255,255,255,0.98);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
    }
    .nav-links.open { display: flex; }
    .nav-links a {
      font-size: 1.2rem;
      letter-spacing: 3px;
      padding: 0.7rem 2rem;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navToggle');
  const links  = document.getElementById('navLinks');

  // Scroll → shrink navbar
  window.addEventListener('scroll', () =>
    navbar?.classList.toggle('scrolled', window.scrollY > 40)
  );

  // Mobile menu toggle
  toggle?.addEventListener('click', () => links?.classList.toggle('open'));
  links?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => links.classList.remove('open'))
  );

  // Scroll-spy: highlight active section link
  const sections = ['home','about','brands','posts','services','contact']
    .map(id => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  const navAnchors = links?.querySelectorAll<HTMLAnchorElement>('a[href^="#"]');

  function setActive() {
    const scrollY = window.scrollY + 100;
    let current = sections[0]?.id ?? '';
    for (const sec of sections) {
      if (sec.offsetTop <= scrollY) current = sec.id;
    }
    navAnchors?.forEach(a => {
      a.classList.toggle('active', a.getAttribute('href') === `#${current}`);
    });
  }

  window.addEventListener('scroll', setActive, { passive: true });
  setActive();
</script>
