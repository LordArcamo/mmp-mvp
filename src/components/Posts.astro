---
const posts = [
  {
    img: "/posts/post-midea-aircon.jpg",
    caption: "Stay COOL this summer without breaking the budget! Midea Aircons starting at ₱15,990 — FREE installation, FREE delivery, with installment options and zero downpayment available.",
    price: "₱15,990",
    product: "Midea Aircon",
    date: "Apr 15, 2026",
    likes: 12,
    label: "Summer Deal",
  },
  {
    img: "/posts/post-fujidenzo-chiller.jpg",
    caption: "Fujidenzo 7.0 cu.ft Showcase Chiller Inverter at ₱22,990 — energy-efficient, spacious storage, perfect for sari-sari stores, mini marts, and home use. Zero downpayment via Billease!",
    price: "₱22,990",
    product: "Fujidenzo Chiller",
    date: "Apr 14, 2026",
    likes: 8,
    label: "Featured",
  },
  {
    img: "/posts/post-astron-washer.jpg",
    caption: "Astron 9.5kg AutoWash Washing Machine at ₱12,490 — fully automatic, large capacity. ZERO downpayment, only ₱1,550/month for 12 months via Billease!",
    price: "₱12,490",
    product: "Astron Washer",
    date: "Apr 14, 2026",
    likes: 15,
    label: "Best Seller",
  },
];
---

<section class="posts" id="posts">
  <div class="posts-inner">

    <div class="posts-header">
      <span class="section-eyebrow reveal from-left">
        <i class="fi fi-br-facebook"></i>
        From Our Facebook Page
      </span>
      <div class="posts-header-row">
        <h2 class="section-heading reveal">
          Latest From<br />
          <span class="red">MMP Marketing</span>
        </h2>
        <a
          href="https://www.facebook.com/mmp.iligan"
          target="_blank"
          rel="noopener noreferrer"
          class="see-all-btn reveal from-right delay-2"
        >
          <i class="fi fi-br-facebook"></i>
          Follow on Facebook
          <i class="fi fi-rr-arrow-right"></i>
        </a>
      </div>
    </div>

    <div class="posts-grid">
      {posts.map((p, i) => (
        <article class={`post-card reveal delay-${i + 1}`}>
          <!-- Image -->
          <div class="post-img-wrap">
            <img
              src={p.img}
              alt={p.product}
              class="post-img"
              loading="lazy"
            />
            <span class="post-label">{p.label}</span>
            <span class="post-price">{p.price}</span>
          </div>

          <!-- Body -->
          <div class="post-body">
            <div class="post-meta">
              <span class="post-page">
                <span class="page-avatar">
                  <span class="av-m1">M</span><span class="av-m2">M</span><span class="av-m3">P</span>
                </span>
                Mmp Iligan
              </span>
              <span class="post-date">{p.date}</span>
            </div>
            <p class="post-product">{p.product}</p>
            <p class="post-caption">{p.caption}</p>
            <div class="post-footer">
              <span class="post-likes">
                <i class="fi fi-sr-heart"></i>
                {p.likes}
              </span>
              <a
                href="https://www.facebook.com/mmp.iligan"
                target="_blank"
                rel="noopener noreferrer"
                class="post-share"
              >
                <i class="fi fi-rr-share"></i>
                View on Facebook
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .posts {
    padding: 8rem 2.5rem;
    background: var(--bg-soft);
    position: relative;
    overflow: hidden;
  }

  .posts-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }

  .posts-header { margin-bottom: 3rem; }

  .posts-header-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .see-all-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: rgba(24,119,242,0.08);
    border: 1px solid rgba(24,119,242,0.25);
    border-radius: 3px;
    color: #1877F2;
    text-decoration: none;
    font-family: var(--font-condensed);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: background 0.3s, border-color 0.3s;
    white-space: nowrap;
    align-self: flex-end;
    margin-bottom: 0.5rem;
  }
  .see-all-btn:hover {
    background: rgba(24,119,242,0.15);
    border-color: rgba(24,119,242,0.4);
  }
  .see-all-btn i { font-size: 0.9rem; }

  /* ── Posts grid ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .post-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(11,20,36,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s;
  }

  .post-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(11,20,36,0.12);
    border-color: rgba(200,16,46,0.25);
  }

  /* Image */
  .post-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--bg-muted);
  }

  .post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transform: scale(1);
    transition: transform 0.6s ease;
  }

  .post-card:hover .post-img {
    transform: scale(1.08);
  }

  .post-label {
    position: absolute;
    top: 0.75rem; left: 0.75rem;
    background: var(--red);
    color: #FFFFFF;
    font-family: var(--font-condensed);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 2px;
  }

  /* Price badge — bottom right of image */
  .post-price {
    position: absolute;
    bottom: 0.75rem; right: 0.75rem;
    background: rgba(11,20,36,0.82);
    backdrop-filter: blur(8px);
    color: #FFFFFF;
    font-family: var(--font-logo);
    font-size: 1.05rem;
    letter-spacing: 1px;
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  /* Body */
  .post-body { padding: 1.2rem 1.4rem 1.4rem; }

  /* Product name */
  .post-product {
    font-family: var(--font-condensed);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--ink);
    margin-bottom: 0.35rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.8rem;
  }

  .post-page {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-condensed);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.5px;
  }

  /* Mini MMP avatar */
  .page-avatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--bg-muted);
    border: 1px solid var(--border-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-logo);
    font-size: 0.55rem;
    letter-spacing: 0px;
    flex-shrink: 0;
  }
  .av-m1, .av-m3 { color: var(--navy); }
  .av-m2 { color: var(--red); }

  .post-date {
    font-size: 0.72rem;
    color: var(--ink-faint);
    font-weight: 400;
  }

  .post-caption {
    font-size: 0.85rem;
    color: var(--ink-mid);
    line-height: 1.65;
    font-weight: 400;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border);
    padding-top: 0.8rem;
  }

  .post-likes {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--ink-light);
    font-weight: 400;
  }
  .post-likes i { color: #E0415A; font-size: 0.85rem; }

  .post-share {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-condensed);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #1877F2;
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-share:hover { color: #0d5fd4; }
  .post-share i { font-size: 0.8rem; }

  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: 1fr 1fr; }
    .posts-header-row { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
