---
---
<section class="hero" id="home">

  <!-- ── LEFT PANEL ── -->
  <div class="hero-left">
    <div class="hl-inner">

      <div class="hl-eyebrow">
        <span class="dot"></span>
        Iligan City's Trusted Appliance Store
      </div>

      <h1 class="hero-heading">
        <span class="mmp-row">
          <span class="mmp-l1">M</span><span class="mmp-l2">M</span><span class="mmp-l3">P</span>
        </span>
        <span class="mmp-sub">
          <span class="sub-rule"></span>
          <span class="sub-text">APPLIANCES TRADING</span>
          <span class="sub-rule"></span>
        </span>
      </h1>

      <p class="hero-desc">
        Quality brands at honest prices — with flexible installment plans
        so every family can afford the best.
      </p>

      <div class="hero-actions">
        <a href="#brands" class="btn-red">
          <i class="fi fi-sr-shop"></i>
          Shop Brands
        </a>
        <a href="#contact" class="btn-ghost">
          <i class="fi fi-rr-phone-call"></i>
          Contact Us
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-n">8<span class="stat-plus">+</span></span>
          <span class="stat-l">Brands</span>
        </div>
        <span class="stat-div"></span>
        <div class="stat">
          <span class="stat-n">₱0</span>
          <span class="stat-l">Down</span>
        </div>
        <span class="stat-div"></span>
        <div class="stat">
          <span class="stat-n">100<span class="stat-plus">%</span></span>
          <span class="stat-l">Quality</span>
        </div>
      </div>

    </div>

    <a href="#about" class="scroll-down" aria-label="Scroll down">
      <div class="sd-line"></div>
      <span>SCROLL</span>
    </a>
  </div>

  <!-- ── RIGHT PANEL ── -->
  <div class="hero-right">
    <img
      class="hero-img"
      src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1200&q=85"
      alt="Home appliance store"
      loading="eager"
      fetchpriority="high"
    />
    <div class="img-edge-fade"></div>
    <div class="img-bottom-fade"></div>

    <div class="chip-location">
      <i class="fi fi-sr-map-marker"></i>
      <span>Tambo Highway, Iligan City</span>
    </div>

    <div class="chip-billease">
      <i class="fi fi-sr-credit-card"></i>
      <div>
        <span class="chip-label">Installment via</span>
        <span class="chip-brand">BILLEASE</span>
      </div>
    </div>

    <div class="chip-zero">
      <span class="cz-value">₱0</span>
      <span class="cz-label">Downpayment</span>
    </div>
  </div>

</section>

<style>
  /* ─────────────────────────
     WRAPPER
  ───────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 55% 45%;
    min-height: 100vh;
    position: relative;
  }

  /* ─────────────────────────
     LEFT — navy panel
  ───────────────────────── */
  .hero-left {
    background: var(--navy);
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* top: navbar clearance · left: mirrors navbar's centered gutter */
    padding: 7rem 3rem 4rem max(2.5rem, calc((100vw - 1200px) / 2));
    position: relative;
    /* clip only horizontal overflow; don't hide the scroll indicator */
    overflow-x: clip;
    overflow-y: visible;
  }

  /* depth: red glow bottom-left + vignette top-right + diagonal hatching */
  .hero-left::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at -5% 110%, rgba(200,16,46,0.26), transparent 65%),
      radial-gradient(ellipse 50% 45% at 110%  -5%, rgba(19,32,57,0.9),  transparent 60%),
      repeating-linear-gradient(
        -52deg,
        transparent 0px, transparent 30px,
        rgba(255,255,255,0.015) 30px, rgba(255,255,255,0.015) 31px
      );
    pointer-events: none;
    z-index: 0;
  }

  /* red seam on the right edge */
  .hero-left::after {
    content: '';
    position: absolute; top: 0; right: 0;
    width: 3px; height: 100%;
    background: linear-gradient(to bottom,
      transparent 5%,
      var(--red) 30%, var(--red) 70%,
      transparent 95%);
    z-index: 2;
  }

  /* ── inner content ── */
  .hl-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    /* keep everything left-aligned */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* eyebrow */
  .hl-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.36);
    margin-bottom: 1.4rem;
    animation: fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s both;
  }

  .dot {
    width: 6px; height: 6px;
    background: var(--red);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.2; transform: scale(0.35); }
  }

  /* ── H1: MMP ── */
  .hero-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    /* prevent heading from overflowing the column */
    width: 100%;
  }

  .mmp-row {
    display: flex;
    align-items: baseline;
    line-height: 0.9;
    letter-spacing: -2px;
  }

  .mmp-l1, .mmp-l2, .mmp-l3 {
    font-family: var(--font-logo);
    font-size: clamp(4.5rem, 8vw, 8.5rem);
    display: inline-block;
  }

  .mmp-l1, .mmp-l3 {
    color: #fff;
    animation: letterDrop 0.8s cubic-bezier(0.16,1,0.3,1) both;
  }
  .mmp-l1 { animation-delay: 0.18s; }
  .mmp-l3 { animation-delay: 0.38s; }

  .mmp-l2 {
    color: var(--red);
    text-shadow: 0 0 48px rgba(200,16,46,0.5);
    animation: letterDrop 0.8s cubic-bezier(0.16,1,0.3,1) 0.28s both;
  }

  @keyframes letterDrop {
    from { opacity: 0; transform: translateY(48px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* "APPLIANCES TRADING" — constrained to the MMP letters width */
  .mmp-sub {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.5rem;
    /* match visual width of the MMP letters */
    align-self: stretch;
    animation: fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.5s both;
  }

  .sub-rule {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,0.12);
    /* cap so it doesn't push text into overflow */
    max-width: 56px;
  }

  .sub-text {
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: clamp(0.65rem, 1.1vw, 0.95rem);
    letter-spacing: clamp(3px, 0.6vw, 7px);
    color: rgba(255,255,255,0.48);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* description */
  .hero-desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.46);
    line-height: 1.8;
    margin-bottom: 1.8rem;
    font-weight: 300;
    max-width: 38ch;
    animation: fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.6s both;
  }

  /* CTA buttons */
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.72s both;
  }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.8rem;
    background: transparent;
    color: rgba(255,255,255,0.62);
    font-family: var(--font-condensed); font-weight: 700;
    font-size: 0.88rem; letter-spacing: 2px; text-transform: uppercase;
    text-decoration: none; border-radius: 3px;
    border: 2px solid rgba(255,255,255,0.16);
    transition: all 0.25s ease;
  }
  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.5);
    color: #fff;
    transform: translateY(-2px);
  }

  /* stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 1.8rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    width: 100%;
    animation: fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.84s both;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-n {
    font-family: var(--font-logo);
    font-size: 1.9rem;
    color: #fff;
    line-height: 1;
  }
  .stat-plus { color: var(--red); font-size: 1.1rem; }

  .stat-l {
    font-family: var(--font-condensed);
    font-size: 0.58rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.36);
    font-weight: 600;
  }

  .stat-div {
    width: 1px; height: 34px;
    background: rgba(255,255,255,0.1);
    flex-shrink: 0;
  }

  /* scroll indicator */
  .scroll-down {
    position: absolute;
    bottom: 2rem;
    left: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    z-index: 3;
    animation: fadeIn 1s ease 1.6s both;
  }

  .sd-line {
    width: 1px; height: 36px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.3));
    animation: lineGrow 1.5s ease-in-out infinite;
  }

  @keyframes lineGrow {
    0%,100% { opacity: 0.5; transform: scaleY(1);    transform-origin: top; }
    50%      { opacity: 1;   transform: scaleY(1.2); }
  }

  .scroll-down span {
    font-family: var(--font-condensed);
    font-size: 0.5rem;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.25);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ─────────────────────────
     RIGHT — image panel
  ───────────────────────── */
  .hero-right {
    position: relative;
    overflow: hidden;
    background: var(--navy);
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    animation: slowZoom 10s ease-in-out infinite alternate;
  }

  @keyframes slowZoom {
    from { transform: scale(1); }
    to   { transform: scale(1.07); }
  }

  .img-edge-fade {
    position: absolute; inset: 0;
    background: linear-gradient(to right,
      rgba(11,20,36,0.6) 0%,
      rgba(11,20,36,0.15) 25%,
      transparent 55%);
    pointer-events: none;
    z-index: 1;
  }

  .img-bottom-fade {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 45%;
    background: linear-gradient(to top, rgba(11,20,36,0.5), transparent);
    pointer-events: none;
    z-index: 1;
  }

  /* ── chips ── */
  .chip-location {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    display: flex; align-items: center; gap: 0.45rem;
    background: rgba(255,255,255,0.93);
    backdrop-filter: blur(10px);
    border-radius: 100px;
    padding: 0.45rem 0.9rem;
    box-shadow: 0 4px 16px rgba(11,20,36,0.2);
    font-family: var(--font-condensed);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--ink-mid);
    z-index: 4;
    animation: chipIn 0.7s cubic-bezier(0.16,1,0.3,1) 0.9s both;
  }
  .chip-location i { color: var(--red); font-size: 0.8rem; }

  .chip-billease {
    position: absolute;
    bottom: 1.5rem; left: 1.5rem;
    display: flex; align-items: center; gap: 0.6rem;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(200,16,46,0.15);
    border-radius: 8px;
    padding: 0.6rem 1rem;
    box-shadow: 0 8px 24px rgba(11,20,36,0.22);
    z-index: 4;
    animation: chipIn 0.7s cubic-bezier(0.16,1,0.3,1) 1.1s both;
  }
  .chip-billease i { font-size: 1.15rem; color: var(--red); }
  .chip-billease > div { display: flex; flex-direction: column; gap: 0.04rem; }

  .chip-label {
    font-family: var(--font-condensed);
    font-size: 0.5rem; letter-spacing: 2px; text-transform: uppercase;
    color: var(--ink-light); font-weight: 600;
  }
  .chip-brand {
    font-family: var(--font-logo);
    font-size: 0.9rem; color: var(--navy); letter-spacing: 2px;
  }

  .chip-zero {
    position: absolute;
    /* sit above the billease chip on the right */
    bottom: 1.5rem; right: 1.5rem;
    display: flex; flex-direction: column; align-items: center;
    background: var(--red);
    border-radius: 8px;
    padding: 0.55rem 0.85rem;
    box-shadow: 0 8px 22px rgba(200,16,46,0.4);
    z-index: 4;
    animation: chipIn 0.7s cubic-bezier(0.16,1,0.3,1) 1.25s both;
    text-align: center;
    min-width: 64px;
  }
  .cz-value {
    font-family: var(--font-logo);
    font-size: 1.4rem; color: #fff; line-height: 1;
  }
  .cz-label {
    font-family: var(--font-condensed);
    font-size: 0.48rem; letter-spacing: 1.5px; text-transform: uppercase;
    color: rgba(255,255,255,0.78); font-weight: 700;
    margin-top: 0.12rem;
    white-space: nowrap;
  }

  @keyframes chipIn {
    from { opacity: 0; transform: scale(0.85) translateY(8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ─────────────────────────
     RESPONSIVE
  ───────────────────────── */
  @media (max-width: 1100px) {
    .hero { grid-template-columns: 1fr 1fr; }
    .hero-left { padding: 7rem 2.5rem 4rem 3rem; }
    .scroll-down { left: 3rem; }
  }

  @media (max-width: 860px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 7rem 2rem 3.5rem; overflow: hidden; }
    .scroll-down { display: none; }
    .hero-right { height: 55vw; min-height: 260px; }
    .img-edge-fade { display: none; }
    .mmp-l1,.mmp-l2,.mmp-l3 { font-size: clamp(3.8rem, 16vw, 7rem); }
    .sub-text { letter-spacing: 4px; font-size: 0.68rem; }
  }

  @media (max-width: 540px) {
    .hero-left { padding: 5.5rem 1.5rem 3rem; }
    .hero-right { height: 62vw; }
    .hero-stats { gap: 1rem; }
    .chip-zero { display: none; }
    .mmp-l1,.mmp-l2,.mmp-l3 { font-size: clamp(3.2rem, 18vw, 6rem); }
  }
</style>
