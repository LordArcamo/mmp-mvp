---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "MMP Appliances Trading",
  description = "Your trusted appliance store in Iligan City. Quality brands, affordable prices, flexible installment plans.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Fonts: Black Han Sans (logo) + Plus Jakarta Sans (body) + Barlow Condensed (labels) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;500;600;700;900&display=swap" rel="stylesheet" />

    <!-- Flaticon uicons -->
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/2.6.0/uicons-regular-rounded/css/uicons-regular-rounded.css" />
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/2.6.0/uicons-solid-rounded/css/uicons-solid-rounded.css" />
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/2.6.0/uicons-brands/css/uicons-brands.css" />

    <style is:global>
      /* ─── MMP Brand Tokens ─── */
      :root {
        --red:        #C8102E;
        --red-dark:   #9B0D23;
        --red-light:  #F5E8EB;
        --red-glow:   rgba(200,16,46,0.25);

        --navy:       #0B1424;
        --navy-mid:   #132039;
        --navy-light: #1C3059;

        /* White-first palette */
        --bg:         #FFFFFF;
        --bg-soft:    #F6F8FB;
        --bg-muted:   #EDF0F5;
        --border:     #E2E7EE;
        --border-dark:#CBD3DE;

        /* Text */
        --ink:        #0B1424;
        --ink-mid:    #2C3E55;
        --ink-light:  #5A6A7E;
        --ink-faint:  #9AAAB8;

        /* Fonts */
        --font-logo:      'Black Han Sans', sans-serif;
        --font-condensed: 'Barlow Condensed', sans-serif;
        --font-body:      'Plus Jakarta Sans', sans-serif;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--ink);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      /* ─── Scroll reveal ─── */
      .reveal {
        opacity: 0;
        transform: translateY(32px);
        transition: opacity 0.75s cubic-bezier(0.16,1,0.3,1),
                    transform 0.75s cubic-bezier(0.16,1,0.3,1);
      }
      .reveal.from-left  { transform: translateX(-44px); }
      .reveal.from-right { transform: translateX(44px); }
      .reveal.scale-up   { transform: scale(0.93); opacity: 0; }
      .reveal.visible    { opacity: 1 !important; transform: none !important; }

      .delay-1 { transition-delay: 0.08s; }
      .delay-2 { transition-delay: 0.18s; }
      .delay-3 { transition-delay: 0.28s; }
      .delay-4 { transition-delay: 0.38s; }
      .delay-5 { transition-delay: 0.48s; }

      /* ─── Shared eyebrow ─── */
      .eyebrow, .section-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-condensed);
        font-weight: 700;
        font-size: 0.72rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--red);
        margin-bottom: 1rem;
      }
      .eyebrow i, .section-eyebrow i { font-size: 0.8rem; }

      /* ─── Shared section heading ─── */
      .sh, .section-heading {
        font-family: var(--font-logo);
        font-size: clamp(2.2rem, 4vw, 3.6rem);
        line-height: 1.05;
        color: var(--navy);
        letter-spacing: 0.5px;
        margin-bottom: 1rem;
      }
      .sh .accent, .section-heading .red { color: var(--red); }

      /* ─── MMP logo mark (reusable) ─── */
      .mmp-mark {
        font-family: var(--font-logo);
        letter-spacing: 1px;
        line-height: 1;
        display: inline-block;
      }
      .mmp-mark .l1, .mmp-mark .l3 { color: var(--navy); }
      .mmp-mark .l2 { color: var(--red); }

      /* ─── Buttons ─── */
      .btn-red {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.85rem 2rem;
        background: var(--red); color: #fff;
        font-family: var(--font-condensed); font-weight: 700;
        font-size: 0.88rem; letter-spacing: 2px; text-transform: uppercase;
        text-decoration: none; border-radius: 3px; border: 2px solid var(--red);
        transition: all 0.25s ease;
      }
      .btn-red:hover {
        background: var(--red-dark); border-color: var(--red-dark);
        transform: translateY(-2px); box-shadow: 0 8px 24px var(--red-glow);
      }
      .btn-outline {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.85rem 2rem;
        background: transparent; color: var(--navy);
        font-family: var(--font-condensed); font-weight: 700;
        font-size: 0.88rem; letter-spacing: 2px; text-transform: uppercase;
        text-decoration: none; border-radius: 3px; border: 2px solid var(--border-dark);
        transition: all 0.25s ease;
      }
      .btn-outline:hover {
        border-color: var(--navy); background: var(--navy); color: #fff;
        transform: translateY(-2px);
      }

      ::selection { background: var(--red); color: #fff; }
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: var(--bg-soft); }
      ::-webkit-scrollbar-thumb { background: var(--red); border-radius: 2px; }
    </style>
  </head>
  <body>
    <slot />
    <script>
      const io = new IntersectionObserver(
        (entries) => entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        }),
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(el => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('visible');
        else io.observe(el);
      });
    </script>
  </body>
</html>
